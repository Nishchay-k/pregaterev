generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  targetExam  String   @default("CSE")
  targetScore Int      @default(65)
  dailyHours  Float    @default(4)
  targetDate  String   @default("2025-02-02")
  theme       String   @default("dark")
  createdAt   DateTime @default(now())

  progress     UserTopicProgress[]
  sessions     StudySession[]
  testAttempts TestAttempt[]
  revisions    Revision[]
  notes        Note[]
  bookmarks    Bookmark[]
  analytics    Analytics?
}

model Subject {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  color       String   @default("#3b82f6")
  order       Int      @default(0)
  exams       String   @default("CSE")
  topics      Topic[]
  questions   Question[]
}

model Topic {
  id             String   @id @default(cuid())
  name           String
  difficulty     String   @default("Medium")
  weightage      Float    @default(5)
  estimatedHours Float    @default(10)
  exams          String   @default("CSE")
  subjectId      String
  subject        Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  questions      Question[]
  userProgress   UserTopicProgress[]
  notes          Note[]
  revisions      Revision[]
}

model UserTopicProgress {
  id        String   @id @default(cuid())
  status    String   @default("Not Started")
  userId    String
  topicId   String
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  @@unique([userId, topicId])
}

model Question {
  id            String   @id @default(cuid())
  questionText  String
  optionA       String   @default("")
  optionB       String   @default("")
  optionC       String   @default("")
  optionD       String   @default("")
  correctOption Int      @default(0)
  correctOptions String  @default("")
  natAnswer     Float?
  natTolerance  Float    @default(0.01)
  explanation   String   @default("")
  year          Int?
  marks         Float    @default(1)
  difficulty    String   @default("Medium")
  questionType  String   @default("MCQ")
  source        String   @default("PYQ")
  subjectId     String
  topicId       String
  subject       Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topic         Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  answers       Answer[]
  bookmarks     Bookmark[]
  revisions     Revision[]
}

model Test {
  id          String       @id @default(cuid())
  name        String
  description String       @default("")
  duration    Int          @default(60)
  totalMarks  Float        @default(20)
  type        String       @default("Topic Test")
  subjectIds  String       @default("")
  topicIds    String       @default("")
  createdAt   DateTime     @default(now())
  attempts    TestAttempt[]
}

model TestAttempt {
  id          String    @id @default(cuid())
  score       Float     @default(0)
  totalMarks  Float     @default(0)
  accuracy    Float     @default(0)
  timeSpent   Int       @default(0)
  status      String    @default("In Progress")
  userId      String
  testId      String
  startedAt   DateTime  @default(now())
  submittedAt DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  test        Test      @relation(fields: [testId], references: [id], onDelete: Cascade)
  answers     Answer[]
}

model Answer {
  id             String      @id @default(cuid())
  selectedOption Int?
  selectedOptions String     @default("")
  natAnswer      Float?
  isCorrect      Boolean     @default(false)
  isMarkedReview Boolean     @default(false)
  timeSpent      Int         @default(0)
  attemptId      String
  questionId     String
  attempt        TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Revision {
  id               String   @id @default(cuid())
  nextRevisionDate DateTime @default(now())
  interval         Int      @default(1)
  easeFactor       Float    @default(2.5)
  revisionCount    Int      @default(0)
  lastRating       String   @default("Medium")
  source           String   @default("Manual")
  userId           String
  questionId       String?
  topicId          String?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question         Question? @relation(fields: [questionId], references: [id], onDelete: Cascade)
  topic            Topic?    @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model StudySession {
  id                 String   @id @default(cuid())
  duration           Int      @default(30)
  questionsAttempted Int      @default(0)
  questionsCorrect   Int      @default(0)
  date               DateTime @default(now())
  userId             String
  topicId            String?
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String
  tags      String   @default("")
  isPinned  Boolean  @default(false)
  userId    String
  topicId   String?
  subjectId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic     Topic?   @relation(fields: [topicId], references: [id])
}

model Analytics {
  id                      String @id @default(cuid())
  totalQuestionsAttempted Int    @default(0)
  totalCorrect            Int    @default(0)
  totalHoursStudied       Float  @default(0)
  studyStreak             Int    @default(0)
  longestStreak           Int    @default(0)
  userId                  String @unique
  user                    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  @@unique([userId, questionId])
}
